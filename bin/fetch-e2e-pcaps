#!/usr/bin/env bash
#
# fetch-e2e-pcaps — populate tests/fixtures/local-samples/ with the local-only
# E2E packet captures (downloads the real ones, regenerates the synthetic one),
# verifying every sha256. The captures themselves are gitignored; this script
# and tests/fixtures/E2E-PCAPS.md are the tracked way to reproduce them.
#
# Usage:
#   bin/fetch-e2e-pcaps          # fetch missing/changed, verify checksums
#   bin/fetch-e2e-pcaps --force  # re-download even if present
#
set -euo pipefail

# Resolve repo root (dir containing this script is <root>/bin).
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEST="$ROOT/tests/fixtures/local-samples"
mkdir -p "$DEST"

FORCE=0
[[ "${1:-}" == "--force" ]] && FORCE=1

# name | sha256 | url   (one real capture per line)
REAL_CAPTURES=(
  "4SICS-GeekLounge-151020.pcap|8c6ee02dc26b1b5298a7c9b4dc83cc779bd2a3219d5c5cbc51e3d4d325763bc2|https://share.netresec.com/s/xYj2qCNbsLEAd6M/download/4SICS-GeekLounge-151020.pcap"
  "4SICS-GeekLounge-151021.pcap|7365b0ea475b76bf79b207fd8f83baa45e4449aead5da6a9214bbcffbc5fa7de|https://share.netresec.com/s/camL59aoxbCRyyZ/download/4SICS-GeekLounge-151021.pcap"
  "4SICS-GeekLounge-151022.pcap|82529c23906416dc73d7f1926a0d38b82527f1f2a7ff8c6f755ce3208feb9643|https://share.netresec.com/s/gw6Y2QzJHqDD5pr/download/4SICS-GeekLounge-151022.pcap"
)

# Synthetic capture: regenerated by its deterministic generator.
SYNTH_NAME="modbus-large.pcap"
SYNTH_SHA="1286603a7c83ca28de7eb46bc93271acd86ce3121f8fe695a744491cc22e5966"
SYNTH_GEN="$ROOT/tests/fixtures/mk_modbus_large_pcap.py"

sha256_of() {
  if command -v shasum >/dev/null 2>&1; then shasum -a 256 "$1" | awk '{print $1}'
  else sha256sum "$1" | awk '{print $1}'; fi
}

verify() { # path expected_sha
  local got; got="$(sha256_of "$1")"
  if [[ "$got" != "$2" ]]; then
    echo "  ✗ checksum MISMATCH for $(basename "$1")" >&2
    echo "    expected $2" >&2
    echo "    got      $got" >&2
    return 1
  fi
  echo "  ✓ $(basename "$1") ($got)"
}

echo "Fetching E2E captures into $DEST"

for entry in "${REAL_CAPTURES[@]}"; do
  IFS='|' read -r name sha url <<<"$entry"
  out="$DEST/$name"
  if [[ -f "$out" && $FORCE -eq 0 ]] && [[ "$(sha256_of "$out")" == "$sha" ]]; then
    echo "  • $name already present and verified — skipping"
    continue
  fi
  echo "  ↓ downloading $name"
  curl -fL --retry 3 -o "$out" "$url"
  verify "$out" "$sha"
done

# Regenerate the synthetic capture (deterministic; writes into local-samples/).
echo "  ⚙ regenerating $SYNTH_NAME"
python3 "$SYNTH_GEN" >/dev/null
verify "$DEST/$SYNTH_NAME" "$SYNTH_SHA"

echo "Done. Try:"
echo "  cargo build --release && ./target/release/wirerust --no-color analyze --modbus \\"
echo "    tests/fixtures/local-samples/4SICS-GeekLounge-151022.pcap"
