  # D2 gratuitous ARP / HSRP (PacketLife backup; credit Jeremy Stretch)
  "gratuitous-arp-hsrp.cap|e2fcc1276f31535d7e6bc5305e979ca1d5b83c7a0db1967d6334cd9b98afe7ad|https://raw.githubusercontent.com/epiecs/packetlife-backup/master/pcaps/gratuitous%20arp%20hsrp.cap"
  # D1 spoof + D12 MAC mismatch (researcher111/ARP-pcap-files; no LICENSE — local use only)
  "arpspoof.pcap|0ce605556689edec01ef50703df7cc88c97a0d1731c4938d54cabcb28a71837a|https://raw.githubusercontent.com/researcher111/ARP-pcap-files/master/arpspoof.pcap"
  # Benign baseline (Practical Packet Analysis / markofu/pcaps; no LICENSE — local use only)
  "ppa-arp.pcap|ea22826b52c96a2038d1c44eb0e7c35dbf40335f82a20cf94ef70bb821033f65|https://raw.githubusercontent.com/markofu/pcaps/master/PracticalPacketAnalysis/ppa-capture-files/arp.pcap"
  # Benign baseline pcapng (PacketLife backup; .cap extension is misleading — pcapng magic; wirerust rejects until pcapng support added)
  "arp-baseline-16pkt.cap|d931e3c27cfb27d006dc6e912671443c88c243efd69b4671f900e0c06cf9ae25|https://raw.githubusercontent.com/epiecs/packetlife-backup/master/pcaps/arp_pcap.pcapng.cap"
  # DNP3 scale capture — igbe/DNP3-Dataset-Plus-SnortRules (no explicit LICENSE — local use only, not redistributed)
  # Exposed BUG-DNP3-CONTROL-OP-DETERMINISM-001; fixed in v0.9.2
  "dnp3dataset_capture.pcap|72551ac30b30c80ee1a0a032e950648f1f70592642880656a1f8e4b5306e5b20|https://raw.githubusercontent.com/igbe/DNP3-Dataset-Plus-SnortRules/master/dnp3dataset_capture.pcap"
  # TLS weak-crypto fixture — Wireshark SampleCaptures (no per-file license; public sample; credit Wireshark Foundation; not redistributed)
  "rsasnakeoil2.pcap|f3f74008e2585d35479b7a234010a584803c240d82723f1f857bac0eb8a8db57|https://gitlab.com/wireshark/wireshark/-/wikis/uploads/__moin_import__/attachments/SampleCaptures/rsasnakeoil2.pcap"
  # iodine DNS-tunneling baseline — elastic/examples (Apache-2.0; credit Elastic)
  # wirerust produces 0 findings (DNS-tunneling not yet implemented); retained as benign-parse baseline and future-detector fixture
  "dns-tunnel-iodine.pcap|91fd221e07107507c8327a9d9487cd7f7531a1fd87cf543b1a76160ff0609b7b|https://raw.githubusercontent.com/elastic/examples/master/Security%20Analytics/dns_tunnel_detection/dns-tunnel-iodine.pcap"
  # --- pcapng block-diversity suite (STORY-128 follow-up: exercises pcapng reader features) ---
  # Canonical Wireshark pcapng example: SHB options (comment/hw/os/app), 2×IDB (LINUX_SLL + ETHERNET),
